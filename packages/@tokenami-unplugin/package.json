  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "tsup": "^8.4.0",
    "typescript": "^5.1.3",
    "vite": "^5.4.21",
    "vitest": "^0.34.6"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
