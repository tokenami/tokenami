{
  "name": "tokenami",
  "version": "0.0.100",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "tokenami/tokenami",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "tokenami": "bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "tsup": "^8.4.0",
    "typescript": "^5.1.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@tokenami/cli": "workspace:*",
    "@tokenami/node": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">= 5"
  }
}
