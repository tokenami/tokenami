{
  "name": "@tokenami/cli",
  "version": "0.0.101",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "tokenami/tokenami",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./bin": {
      "import": "./dist/bin.js"
    }
  },
  "bin": {
    "tokenami": "bin.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tokenami/config": "workspace:*",
    "@tokenami/node": "workspace:*",
    "browserslist": "^4.26.3",
    "cac": "^6.7.14",
    "chokidar": "^3.5.3",
    "inquirer": "^9.3.8",
    "lightningcss": "1.29.1",
    "pathe": "^1.1.1",
    "typescript": "^5.1.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.3.1",
    "tsup": "^8.4.0"
  }
}
