{
  "name": "@tokenami/example-nextjs",
  "version": "0.0.101",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "dev": "pnpm run \"/dev:/\"",
    "dev:app": "next dev --turbopack",
    "dev:css": "tokenami --output ./src/app/tokenami.css --watch",
    "build": "pnpm run \"/build:/\"",
    "build:app": "next build",
    "build:css": "tokenami --output ./src/app/tokenami.css",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tokenami check; tsc --noEmit"
  },
  "dependencies": {
    "@tokenami/css": "workspace:*",
    "@tokenami/ds": "workspace:*",
    "@tokenami/example-design-system": "workspace:*",
    "next": "15.5.18",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "tokenami": "workspace:*",
    "typescript": "^5"
  },
  "browserslist": [
    "supports css-cascade-layers and supports css-has"
  ]
}
